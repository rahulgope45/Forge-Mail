// ============== MODEL USER ===============

model User {
    id                 String   @id @default(cuid())
    email              String   @unique
    name               String?
    avatar             String?
    refreshToken       String?
    googleRefreshToken String?
    googleID           String   @unique
    provider           String   @default("google")
    createdAt          DateTime @default(now())
    updatedAt          DateTime @updatedAt()

    @@map("users")
}
